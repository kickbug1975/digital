<IfModule mod_headers.c>
    # 1. Strict-Transport-Security (HSTS)
    # Exigence maximale pour A+ : includeSubDomains et preload, et max-age >= 1 an (31536000 ou 63072000).
    Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" env=HTTPS

    # 2. X-Content-Type-Options
    Header always set X-Content-Type-Options "nosniff"

    # 3. X-Frame-Options
    Header always set X-Frame-Options "DENY"

    # 4. Referrer-Policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"

    # 5. X-XSS-Protection (Legacy, mais souvent bonifiant)
    Header always set X-XSS-Protection "1; mode=block"

    # 6. Content-Security-Policy (CSP) - TRES STRICTE
    # - default-src 'self' : bloque tout par défaut sauf le domaine actuel.
    # - script-src : plus de 'unsafe-inline' ni 'unsafe-eval' pour passer le test avec succès.
    # - style-src : 'unsafe-inline' est généralement toléré pour Google Fonts, mais restreint.
    # - connect-src : on autorise le domaine actuel et le webhook n8n.
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' https://fonts.googleapis.com 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://n8n.dim1975.shop; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests"

    # 7. Permissions-Policy
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"

    # 8. Cross-Origin-Opener-Policy
    Header always set Cross-Origin-Opener-Policy "same-origin"
</IfModule>

# Redirection automatique HTTP vers HTTPS
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>
